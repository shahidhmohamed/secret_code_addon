<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="secret_codes_action_activate_selected" model="ir.actions.server">
    <field name="name">Selected Status Actions</field>
    <field name="model_id" ref="model_secret_codes"/>
    <field name="binding_model_id" ref="model_secret_codes"/>
    <field name="binding_type">action</field>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="groups_id" eval="[(4, ref('secret_codes.group_secret_codes_access'))]"/>
    <field name="code"><![CDATA[
action = {
    'type': 'ir.actions.act_window',
    'name': 'Selected Status Actions',
    'res_model': 'secret_codes.selection_status_wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {
        'active_model': 'secret_codes',
        'active_ids': records.ids,
    },
}
    ]]></field>
  </record>

  <record id="secret_codes_action_deactivate_selected" model="ir.actions.server">
    <field name="name">Deactivate</field>
    <field name="model_id" ref="model_secret_codes"/>
    <field name="binding_model_id" eval="False"/>
    <field name="binding_type">action</field>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="groups_id" eval="[(4, ref('secret_codes.group_secret_codes_access'))]"/>
    <field name="code">action = False</field>
  </record>
</odoo>
